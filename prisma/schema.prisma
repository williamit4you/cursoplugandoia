generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum VideoAspectRatio {
  PORTRAIT_9_16
  LANDSCAPE_16_9
}

enum CrmLeadStage {
  LEAD
  CONTACTED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum CrmActivityType {
  CALL
  WHATSAPP
  EMAIL
  MEETING
  TASK
  NOTE
  SYSTEM
}

enum CrmActivityDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum CrmTaskStatus {
  OPEN
  DONE
  CANCELED
}

enum AutomationTaskType {
  NEWS_VIDEO
  QA_VIDEO
  MERCADO_LIVRE_VIDEO
  SHOPEE_VIDEO
}

enum AutomationTaskStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum AutomationTriggerType {
  MANUAL
  SCHEDULED
  RETRY
}

enum AutomationRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  PARTIAL
  CANCELED
}

enum AutomationStepStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum ShopeePipelineStatus {
  PENDING
  SCRAPING_MEDIA
  MEDIA_SCRAPED
  GENERATING_COPY
  COPY_READY
  WAITING_POD
  GENERATING_AUDIO
  AUDIO_READY
  GENERATING_COPY_VIDEO
  COPY_VIDEO_READY
  MERGING_VIDEOS
  FINAL_VIDEO_READY
  GENERATING_AFFILIATE_LINK
  AFFILIATE_LINK_READY
  READY_FOR_STORY
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  PAUSED
}

enum ColetaPipelineKind {
  SALES
  ENGAGEMENT
}

enum ShopeePipelineInputMode {
  SCRAPE_SOURCE
  MANUAL_VIDEO
}

enum ShopeePipelineStepStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  RETRY_SCHEDULED
  SKIPPED
}

enum PodSessionStatus {
  OFFLINE
  STARTING
  ONLINE
  BUSY
  IDLE
  STOPPING
  ERROR
}

enum StoryAdStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELED
}

enum StoryPublicationStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
  RETRY_SCHEDULED
  CANCELED
}

enum StoryPlatform {
  TIKTOK
  YOUTUBE
  INSTAGRAM
}

enum ComparisonStatus {
  DRAFT
  QUEUED
  SCRAPING
  ENRICHING
  WRITING
  REVIEWING
  PUBLISHED
  FAILED
  ARCHIVED
}

enum ComparisonItemStatus {
  PENDING
  FETCHING
  SCRAPED
  NORMALIZED
  FAILED
  SKIPPED
}

enum ComparisonStepStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  RETRY_SCHEDULED
  SKIPPED
}

enum SalesPageEventType {
  PAGE_VIEW
  VIEW_CONTENT
  INITIATE_CHECKOUT
  LEAD
  PURCHASE
}

enum SalesPageDeviceType {
  DESKTOP
  MOBILE
  TABLET
  BOT
  UNKNOWN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Armazenará o hash gerado a partir do env inicial
  role      String   @default("ADMIN")
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  crmOwnedContacts CrmContact[]  @relation("CrmContactOwner")
  crmTasks         CrmTask[]     @relation("CrmTaskAssignee")
  crmActivities    CrmActivity[] @relation("CrmActivityAuthor")
  crmSettings      CrmSettings[] @relation("CrmDefaultAssignee")
  videoCleanupJobs VideoCleanupJob[] @relation("VideoCleanupJobOwner")
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  summary     String
  content     String   // Conteúdo em Markdown ou HTML enriquecido
  status      String   @default("DRAFT") // Valores: DRAFT, PUBLISHED
  views       Int      @default(0)
  coverImage  String?  // URL do MinIO
  sourceUrl   String?  @unique // Evita duplicidade de rotinas do robô
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  socialPosts SocialPost[]
  aiUsageLogs AiUsageLog[]
}

model AffiliateComparison {
  id              String             @id @default(cuid())
  title           String
  slug            String             @unique
  theme           String
  targetYear      Int?
  introSummary    String?
  seoTitle        String?
  metaDescription String?
  heroTitle       String?
  heroSubtitle    String?
  contentHtml     String             @default("")
  faqJson         String             @default("[]")
  schemaJson      String             @default("{}")
  status          ComparisonStatus   @default(DRAFT)
  publishedAt     DateTime?
  sourceCount     Int                @default(0)
  validSourceCount Int               @default(0)
  views           Int                @default(0)
  featuredImageUrl String?
  generationModel String?
  generationNotes String?
  errorMessage    String?
  attemptCount    Int                @default(0)
  lastError       String?
  createdByUserId String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  items           AffiliateComparisonItem[]
  steps           AffiliateComparisonStep[]
  events          AffiliateComparisonEvent[]

  @@index([status])
  @@index([publishedAt])
  @@index([theme])
  @@index([createdAt])
}

model AffiliateComparisonItem {
  id                    String               @id @default(cuid())
  comparisonId          String
  comparison            AffiliateComparison  @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  sortOrder             Int                  @default(0)
  sourceUrl             String
  sourceDomain          String
  affiliateUrl          String
  canonicalUrl          String?
  storeName             String?
  productTitle          String?
  brand                 String?
  priceText             String?
  priceValue            Float?
  currency              String?
  imageUrl              String?
  ratingText            String?
  reviewCountText       String?
  shortDescription      String?
  bulletPointsJson      String               @default("[]")
  specsJson             String               @default("{}")
  prosJson              String               @default("[]")
  consJson              String               @default("[]")
  scrapingPayloadJson   String               @default("{}")
  normalizedPayloadJson String               @default("{}")
  status                ComparisonItemStatus @default(PENDING)
  scrapedAt             DateTime?
  errorMessage          String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([comparisonId, sortOrder])
  @@index([status])
  @@unique([comparisonId, sourceUrl])
}

model AffiliateComparisonStep {
  id              String               @id @default(cuid())
  comparisonId    String
  comparison      AffiliateComparison  @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  stepName        String
  status          ComparisonStepStatus @default(PENDING)
  startedAt       DateTime?
  finishedAt      DateTime?
  durationMs      Int?
  attempt         Int                  @default(1)
  nextRetryAt     DateTime?
  errorCode       String?
  errorMessage    String?
  requestPayload  Json?
  responsePayload Json?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([comparisonId])
  @@index([status])
  @@index([stepName])
}

model AffiliateComparisonEvent {
  id           String              @id @default(cuid())
  comparisonId String
  comparison   AffiliateComparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  itemId       String?
  stepName     String?
  level        String              @default("INFO")
  message      String
  metadata     Json?
  createdAt    DateTime            @default(now())

  @@index([comparisonId, createdAt])
  @@index([itemId])
}

model AffiliateComparisonConfig {
  id                    String   @id @default(cuid())
  isEnabled             Boolean  @default(true)
  autoPublish           Boolean  @default(true)
  maxLinksPerComparison Int      @default(20)
  requestTimeoutMs      Int      @default(30000)
  aiModel               String   @default("gpt-4o-mini")
  reviewerModel         String   @default("gpt-4o-mini")
  writerTemperature     Float    @default(0.3)
  reviewerTemperature   Float    @default(0.2)
  defaultYearStrategy   String   @default("CURRENT_YEAR")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model SalesPageEvent {
  id            String              @id @default(cuid())
  pageKey       String
  pagePath      String
  pageTitle     String?
  eventType     SalesPageEventType
  sessionId     String
  visitorId     String?
  source        String              @default("site")
  referrer      String?
  userAgent     String?
  ipHash        String?
  deviceType    SalesPageDeviceType @default(UNKNOWN)
  browser       String?
  os            String?
  country       String?
  region        String?
  city          String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmTerm       String?
  utmContent    String?
  fbclid        String?
  metaEventName String?
  checkoutUrl   String?
  currency      String?
  value         Float?
  orderId       String?
  metadataJson  String              @default("{}")
  occurredAt    DateTime            @default(now())
  createdAt     DateTime            @default(now())

  @@index([pageKey, occurredAt])
  @@index([eventType, occurredAt])
  @@index([sessionId])
  @@index([utmCampaign])
  @@index([pageKey, eventType, occurredAt])
}

model SalesPageSession {
  id                    String              @id @default(cuid())
  sessionId             String              @unique
  pageKey               String
  landingPath           String
  firstReferrer         String?
  firstUtmSource        String?
  firstUtmMedium        String?
  firstUtmCampaign      String?
  firstUtmTerm          String?
  firstUtmContent       String?
  firstFbclid           String?
  firstDeviceType       SalesPageDeviceType @default(UNKNOWN)
  firstUserAgent        String?
  visitorId             String?
  firstSeenAt           DateTime            @default(now())
  lastSeenAt            DateTime            @default(now())
  pageViewCount         Int                 @default(0)
  viewContentCount      Int                 @default(0)
  initiateCheckoutCount Int                 @default(0)
  leadCount             Int                 @default(0)
  purchaseCount         Int                 @default(0)
  revenueTotal          Float               @default(0)

  @@index([pageKey, firstSeenAt])
  @@index([pageKey, lastSeenAt])
}

model SalesPageConfig {
  id               String   @id @default(cuid())
  pageKey          String   @unique
  pagePath         String
  title            String
  metaPixelId      String?
  isActive         Boolean  @default(true)
  trackPageView    Boolean  @default(true)
  trackViewContent Boolean  @default(true)
  trackCheckout    Boolean  @default(true)
  trackLead        Boolean  @default(true)
  trackPurchase    Boolean  @default(true)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ScrapingSource {
  id          String   @id @default(cuid())
  url         String   @unique
  name        String
  isActive    Boolean  @default(true)
  lastScraped DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IntegrationSettings {
  id              String   @id @default(cuid())
  platform        String   @unique // Valores: META, LINKEDIN, INSTAGRAM, N8N, WHATSAPP, YOUTUBE
  apiKey          String?
  apiSecret       String?
  appId           String?
  pageId          String?
  instagramId     String?
  accessToken     String?
  refreshToken    String?
  webhookUrl      String?
  isActive        Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

model SocialPost {
  id          String   @id @default(cuid())
  postId      String?  
  summary     String
  videoUrl    String
  status      String   @default("DRAFT") // DRAFT, SCHEDULED, POSTED, FAILED
  scheduledTo DateTime?
  postedAt    DateTime?
  youtubePostedAt   DateTime?
  metaStoryPostedAt DateTime?
  metaReelPostedAt  DateTime?
  tiktokPostedAt    DateTime?
  linkedinPostedAt  DateTime?

  platform    String   @default("META")
  postType    String   @default("REEL") // REEL | STORY
  log         String?
  thumbUrl    String?  // URL de thumbnail (MinIO)
  metaContainerId String? // ID do container criado na Meta (para publicação async)
  postUrl     String?  // URL pública da postagem
  youtubePostUrl    String?
  metaStoryPostUrl  String?
  metaReelPostUrl   String?
  tiktokPostUrl     String?
  linkedinPostUrl   String?
  views       Int      @default(0) // Visualizações
  clicksCount     Int                @default(0)
  clicks          SocialPostClick[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post        Post?    @relation(fields: [postId], references: [id])
  codeVideoProjectId String?
  codeVideoProject   CodeVideoProject? @relation(fields: [codeVideoProjectId], references: [id])

  automationTaskId    String?
  automationTask      AutomationTask? @relation(fields: [automationTaskId], references: [id], onDelete: SetNull)
  automationTaskRunId String?
  automationTaskRun   AutomationTaskRun? @relation(fields: [automationTaskRunId], references: [id], onDelete: SetNull)

  @@index([automationTaskId])
  @@index([automationTaskRunId])
}

model SocialPostClick {
  id           String     @id @default(cuid())
  socialPostId String
  socialPost   SocialPost @relation(fields: [socialPostId], references: [id], onDelete: Cascade)
  platform     String     // e.g. "YOUTUBE", "TIKTOK", "LINKEDIN", "META"
  referrer     String?
  userAgent    String?
  ipHash       String?    // SHA-256 hash of client IP
  createdAt    DateTime   @default(now())

  @@index([socialPostId])
  @@index([createdAt])
}

model CodeVideoProject {
  id               String           @id @default(cuid())
  status           String           @default("DRAFT") // DRAFT | GENERATING | READY | RENDERING | DONE | FAILED
  projectType      String           @default("GENERIC") // GENERIC | PRODUCT_AD

  // Entrada do usuário
  ideaPrompt       String
  aspectRatio      VideoAspectRatio @default(PORTRAIT_9_16)
  videoDurationSec Int              @default(30)
  fps              Int              @default(30)
  // TTS (worker Python / edge-tts)
  ttsVoice         String           @default("pt-BR-AntonioNeural")
  ttsSpeed         String           @default("+5%")
  useExternalMedia Boolean          @default(false)

  // Conteúdo editável (IA -> usuário pode revisar)
  title            String?
  description      String?
  narrationText    String?
  promptPreview    String?
  metadataJson     String           @default("{}")

  // Plano do vídeo (JSON serializado, validado no backend)
  videoSpecJson    String           @default("{}")

  // Artefatos gerados
  audioUrl         String?
  captionsUrl      String?
  videoUrl         String?
  thumbUrl         String?
  renderProgress   Float            @default(0)

  errorMessage     String?
  log              String?

  pipelineStatus     ShopeePipelineStatus       @default(PENDING)
  videoStatus        String?                    // RENDERING | COMPLETED | FAILED
  attemptCount       Int                        @default(0)
  lastError          String?
  
  // Relations to track logging
  pipelineSteps      CodeVideoPipelineStep[]
  pipelineEvents     CodeVideoPipelineEvent[]

  socialPosts      SocialPost[]
  automationAssetBundles AutomationAssetBundle[]
  question         VideoQuestion?

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model CodeVideoPipelineStep {
  id              String   @id @default(cuid())
  projectId       String
  project         CodeVideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stepName        String
  status          ShopeePipelineStepStatus @default(PENDING)
  startedAt       DateTime?
  finishedAt      DateTime?
  durationMs      Int?
  attempt         Int      @default(1)
  nextRetryAt     DateTime?
  errorCode       String?
  errorMessage    String?
  requestPayload  Json?
  responsePayload Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId])
}

model CodeVideoPipelineEvent {
  id        String   @id @default(cuid())
  projectId String
  project   CodeVideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stepName  String?
  level     String   @default("INFO") // INFO | ERROR | WARN
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
}

model VideoQuestionConfig {
  id                String   @id @default(cuid())
  isEnabled         Boolean  @default(true)

  // Agendamento
  intervalMinutes   Int      @default(60)      // executa a cada X minutos
  scheduledTimes    String   @default("[]")    // JSON: ["08:00","14:00"]
  useScheduledTimes Boolean  @default(false)

  // Limites
  maxQuestionsPerRun Int     @default(3)

  // Defaults do vídeo
  defaultAspectRatio VideoAspectRatio @default(PORTRAIT_9_16)
  videoDurationSec   Int      @default(30)
  fps                Int      @default(30)
  ttsVoice           String   @default("pt-BR-AntonioNeural")
  ttsSpeed           String   @default("+5%")

  // Pós-processo
  autoEnqueueMetaStory  Boolean @default(false)
  autoEnqueueMetaReels  Boolean @default(false)
  autoEnqueueTikTok   Boolean @default(false)
  autoEnqueueLinkedIn Boolean @default(false)
  autoEnqueueYouTube  Boolean @default(false)
  useExternalMedia    Boolean @default(false)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model VideoQuestion {
  id               String   @id @default(cuid())
  questionText     String
  status           String   @default("PENDING") // PENDING | PROCESSING | DONE | FAILED
  errorMessage     String?
  startedAt        DateTime?
  completedAt      DateTime?
  useExternalMedia Boolean   @default(false)

  codeVideoProjectId String? @unique
  codeVideoProject   CodeVideoProject? @relation(fields: [codeVideoProjectId], references: [id])

  pipelineStatus     ShopeePipelineStatus         @default(PENDING)
  videoStatus        String?                      // RENDERING | COMPLETED | FAILED
  attemptCount       Int                          @default(0)
  lastError          String?
  
  // Relations to track logging
  pipelineSteps      VideoQuestionPipelineStep[]
  pipelineEvents     VideoQuestionPipelineEvent[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model VideoQuestionPipelineStep {
  id              String   @id @default(cuid())
  questionId      String
  question        VideoQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  stepName        String
  status          ShopeePipelineStepStatus @default(PENDING)
  startedAt       DateTime?
  finishedAt      DateTime?
  durationMs      Int?
  attempt         Int      @default(1)
  nextRetryAt     DateTime?
  errorCode       String?
  errorMessage    String?
  requestPayload  Json?
  responsePayload Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([questionId])
}

model VideoQuestionPipelineEvent {
  id          String   @id @default(cuid())
  questionId  String
  question    VideoQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  stepName    String?
  level       String   @default("INFO") // INFO | ERROR | WARN
  message     String
  metadata  Json?
  createdAt   DateTime @default(now())

  @@index([questionId])
  @@index([createdAt])
}

model Lead {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String?  // Ref do Post (Slug) para saber onde o lead foi captado
  createdAt DateTime @default(now())
}

model CrmSettings {
  id                     String   @id @default(cuid())
  whatsappEnabled        Boolean  @default(false)
  whatsappDisplayLabel   String   @default("Falar no WhatsApp")
  whatsappNumber         String?
  whatsappDefaultMessage String   @default("Olá! Quero falar sobre automação, agentes de IA e WhatsApp.")
  evolutionEnabled       Boolean  @default(false)
  evolutionBaseUrl       String?
  evolutionApiKey        String?
  evolutionInstanceName  String?
  evolutionWebhookSecret String?
  openAiModel            String   @default("gpt-4o-mini")
  assistantEnabled       Boolean  @default(true)
  assistantScope         String   @default("Automação com n8n, agentes de IA, RAG, WhatsApp, Evolution API, integrações e implantação comercial.")
  assistantSystemPrompt  String   @default("Você é um atendente comercial da Plugando IA. Tire dúvidas apenas sobre automação, n8n, agentes de IA, RAG, WhatsApp, Evolution API, integrações, implantação e consultoria. Se o assunto sair desse escopo, recuse com educação, explique o escopo atendido e convide o lead a voltar ao tema comercial.")
  defaultAssigneeUserId  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  defaultAssignee        User?    @relation("CrmDefaultAssignee", fields: [defaultAssigneeUserId], references: [id])
}

model CrmContact {
  id              String       @id @default(cuid())
  name            String?
  phone           String       @unique
  email           String?      @unique
  company         String?
  source          String?
  interestService String?
  notes           String?
  stage           CrmLeadStage @default(LEAD)
  lastContactAt   DateTime?
  ownerUserId     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  owner           User?              @relation("CrmContactOwner", fields: [ownerUserId], references: [id])
  activities      CrmActivity[]
  tasks           CrmTask[]
  conversations   CrmConversation[]

  @@index([stage])
  @@index([ownerUserId])
  @@index([createdAt])
}

model CrmActivity {
  id           String               @id @default(cuid())
  contactId    String
  type         CrmActivityType
  direction    CrmActivityDirection @default(INTERNAL)
  subject      String?
  content      String
  happenedAt   DateTime             @default(now())
  createdAt    DateTime             @default(now())
  authorUserId String?
  metadataJson String               @default("{}")

  contact      CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author       User?      @relation("CrmActivityAuthor", fields: [authorUserId], references: [id])

  @@index([contactId, happenedAt])
  @@index([type])
}

model CrmTask {
  id               String        @id @default(cuid())
  contactId        String
  title            String
  description      String?
  status           CrmTaskStatus @default(OPEN)
  dueAt            DateTime?
  completedAt      DateTime?
  assignedToUserId String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  contact          CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedTo       User?      @relation("CrmTaskAssignee", fields: [assignedToUserId], references: [id])

  @@index([contactId, status])
  @@index([assignedToUserId])
}

model CrmConversation {
  id               String   @id @default(cuid())
  contactId        String
  channel          String   @default("WHATSAPP")
  status           String   @default("OPEN")
  externalThreadId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  contact          CrmContact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages         CrmMessage[]

  @@index([contactId, updatedAt])
}

model CrmMessage {
  id                 String               @id @default(cuid())
  conversationId     String
  role               String
  direction          CrmActivityDirection @default(INTERNAL)
  content            String
  model              String?
  externalMessageId  String?
  guardrailTriggered Boolean              @default(false)
  createdAt          DateTime             @default(now())

  conversation       CrmConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model PipelineLog {
  id        String   @id @default(cuid())
  step      String   // FETCH, AI, VIDEO, UPLOAD, INGEST, PEXELS, ERROR
  message   String
  level     String   @default("INFO") // INFO, SUCCESS, ERROR, WARN
  createdAt DateTime @default(now())
}

model OperationDefinition {
  id             String          @id @default(cuid())
  key            String          @unique
  name           String
  family         String
  description    String?
  enabled        Boolean         @default(true)
  expectedEverySec Int?
  owner          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  runs           OperationRun[]
}

model OperationRun {
  id              String              @id @default(cuid())
  runId           String              @unique @default(cuid())
  operationKey    String
  status          String              @default("RUNNING") // RUNNING | SUCCESS | PARTIAL | FAILED | STALE
  startedAt       DateTime            @default(now())
  heartbeatAt     DateTime            @default(now())
  finishedAt      DateTime?
  nextRunAt       DateTime?
  itemsFound      Int                 @default(0)
  itemsProcessed  Int                 @default(0)
  itemsSucceeded  Int                 @default(0)
  itemsFailed     Int                 @default(0)
  estimatedCostUsd Float               @default(0)
  errorMessage    String?
  metadataJson    String?
  createdAt       DateTime            @default(now())
  operation       OperationDefinition @relation(fields: [operationKey], references: [key], onDelete: Cascade)

  @@index([operationKey, startedAt])
  @@index([status, heartbeatAt])
  @@index([heartbeatAt])
}

model OperationAlert {
  id            String    @id @default(cuid())
  fingerprint   String    @unique
  operationKey  String?
  severity      String    @default("WARNING") // INFO | WARNING | CRITICAL
