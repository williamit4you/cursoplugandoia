  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products  BioProduct[]
}

model BioProduct {
  id           String   @id @default(cuid())
  coletaId     String   @unique
  coleta       ColetaDadosShoppe @relation(fields: [coletaId], references: [id], onDelete: Cascade)
  slug         String   @unique
  title        String
  description  String
  imageUrl     String?
  videoUrl     String?
  affiliateUrl String
  categoryId   String?
  category     BioCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  active       Boolean  @default(true)
  publishedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clicks       BioClick[]

  @@index([active])
  @@index([publishedAt])
  @@index([categoryId])
}

model BioClick {
  id           String   @id @default(cuid())
  bioProductId String
  bioProduct   BioProduct @relation(fields: [bioProductId], references: [id], onDelete: Cascade)
  source       String?
  userAgent    String?
  ipHash       String?
  createdAt    DateTime @default(now())

  @@index([bioProductId])
  @@index([createdAt])
}

model SimpleCreatorVideo {
  id              String   @id @default(cuid())
  narrationText   String
  creatorImageUrl String
  voiceRefUrl      String?
  audioUrl         String?
  videoUrl         String?
  captionsUrl      String?
  status           String   @default("DRAFT") // DRAFT | GENERATING_AUDIO | AUDIO_READY | GENERATING_VIDEO | READY | FAILED
  audioLanguage    String   @default("Portuguese")
  speechRate       Float    @default(1)
  formatPreset     String   @default("TIKTOK")
  videoWidth       Int      @default(432)
  videoHeight      Int      @default(768)
  videoFps         Int      @default(25)
  audioPromptId    String?
  videoPromptId    String?
  startedAt        DateTime?
  audioStartedAt   DateTime?
  audioCompletedAt DateTime?
  videoStartedAt   DateTime?
  completedAt      DateTime?
  errorMessage     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model MixedCreatorVideo {
  id                  String   @id @default(cuid())
  narrationText       String
  creatorImageUrl     String
  voiceRefUrl         String?
  audioUrl            String?
  talkingHeadVideoUrl String?
  finalVideoUrl       String?
  captionsUrl         String?
  status              String   @default("DRAFT") // DRAFT | PLANNING_VISUALS | GENERATING_AUDIO | GENERATING_TALKING_HEAD | COMPOSING_VIDEO | READY | FAILED
  aspectRatio         String   @default("PORTRAIT_9_16")
  audioLanguage       String   @default("Portuguese")
  speechRate          Float    @default(1)
  assetPlanJson       String   @default("{}")
  renderSpecJson      String   @default("{}")
  errorMessage        String?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  assets              MixedCreatorVideoAsset[]

  @@index([status])
  @@index([createdAt])
}

model MixedCreatorVideoAsset {
  id                 String           @id @default(cuid())
  mixedCreatorVideoId String
  mixedCreatorVideo  MixedCreatorVideo @relation(fields: [mixedCreatorVideoId], references: [id], onDelete: Cascade)
  url                String
  kind               String
  source             String           @default("UPLOAD")
  originalName       String?
  userLabel          String?
  autoLabel          String?
  sortOrder          Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([mixedCreatorVideoId, sortOrder])
}

model VideoCleanupJob {
  id                   String   @id @default(cuid())
  ownerUserId          String
  ownerUser            User     @relation("VideoCleanupJobOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  status               String   @default("UPLOADING") // UPLOADING | QUEUED | PROCESSING | READY | FAILED | CANCELED
  sourceType           String   @default("UPLOAD")
  originalFilename     String?
  mimeType             String?
  inputBucketKey       String?
  inputUrl             String?
  outputBucketKey      String?
  outputUrl            String?
  affiliateUrl         String?   @ignore
  logoBucketKey        String?
  logoUrl              String?
  instagramHandle      String?  @default("@compraesperta.promocoes")
  showTopMessage       Boolean   @default(true) @ignore
  isPublished          Boolean   @default(false) @ignore
  publishedAt          DateTime? @ignore
  endCardDurationSec   Float    @default(2.0)
  durationSec          Float?
  fileSizeBytes        BigInt?
  width                Int?
  height               Int?
  fps                  Float?
  audioMode            String   @default("PRESERVE") // PRESERVE | REDUCE | MUTE
  audioVolumePercent   Int      @default(100)
  outputFormat         String   @default("mp4")
  progressPercent      Float    @default(0)
  currentStep          String?
  estimatedSecondsLeft Int?
  processingStartedAt  DateTime?
  processingFinishedAt DateTime?
  errorMessage         String?
  metadataJson         String   @default("{}")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  steps                VideoCleanupStep[]
  events               VideoCleanupEvent[]

  @@index([ownerUserId, createdAt])
  @@index([status])
  @@index([isPublished, createdAt])
}

model VideoCleanupStep {
  id              String   @id @default(cuid())
  jobId           String
  job             VideoCleanupJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stepName        String
  status          String   @default("PENDING") // PENDING | RUNNING | SUCCESS | FAILED | SKIPPED
  startedAt       DateTime?
  finishedAt      DateTime?
  durationMs      Int?
  errorMessage    String?
  requestPayload  Json?
  responsePayload Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([jobId, stepName])
  @@index([status])
}

model VideoCleanupEvent {
  id        String   @id @default(cuid())
  jobId     String
  job       VideoCleanupJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  level     String   @default("INFO")
  stepName  String?
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([jobId, createdAt])
}

model CreatorAsset {
  id        String   @id @default(cuid())
  kind      String   @default("IMAGE") // IMAGE (MVP)
  label     String?
  url       String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind])
  @@index([active])
  @@unique([url])
}

model EngagementIdea {
  id            String   @id @default(cuid())
  coletaId      String?
  templateType  String
  personaName   String?
  hook          String
  script        String
  onScreenText  Json     @default("[]")
  ctaComment    String?
  status        String   @default("DRAFT") // DRAFT | APPROVED | GENERATING_AUDIO | AUDIO_READY | GENERATING_VIDEO | READY | FAILED | DISMISSED
  creatorImageUrl String?
  audioUrl      String?
  videoUrl      String?
  captionsUrl   String?
  errorMessage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  coleta        ColetaDadosShoppe? @relation(fields: [coletaId], references: [id], onDelete: SetNull)

  @@index([coletaId])
  @@index([templateType])
  @@index([status])
  @@index([createdAt])
}

model CreatorPersona {
  id            String   @id @default(cuid())
  name          String
  imageUrl      String
  voiceRefUrl   String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  coletasShopee ColetaDadosShoppe[]
}
