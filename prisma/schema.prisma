generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum VideoAspectRatio {
  PORTRAIT_9_16
  LANDSCAPE_16_9
}

enum CrmLeadStage {
  LEAD
  CONTACTED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum CrmActivityType {
  CALL
  WHATSAPP
  EMAIL
  MEETING
  TASK
  NOTE
  SYSTEM
}

enum CrmActivityDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum CrmTaskStatus {
  OPEN
  DONE
  CANCELED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Armazenará o hash gerado a partir do env inicial
  role      String   @default("ADMIN")
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  crmOwnedContacts CrmContact[]  @relation("CrmContactOwner")
  crmTasks         CrmTask[]     @relation("CrmTaskAssignee")
  crmActivities    CrmActivity[] @relation("CrmActivityAuthor")
  crmSettings      CrmSettings[] @relation("CrmDefaultAssignee")
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  summary     String
  content     String   // Conteúdo em Markdown ou HTML enriquecido
  status      String   @default("DRAFT") // Valores: DRAFT, PUBLISHED
  views       Int      @default(0)
  coverImage  String?  // URL do MinIO
  sourceUrl   String?  @unique // Evita duplicidade de rotinas do robô
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  socialPosts SocialPost[]
  aiUsageLogs AiUsageLog[]
}

model ScrapingSource {
  id          String   @id @default(cuid())
  url         String   @unique
  name        String
  isActive    Boolean  @default(true)
  lastScraped DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IntegrationSettings {
  id              String   @id @default(cuid())
  platform        String   @unique // Valores: META, LINKEDIN, INSTAGRAM, N8N, WHATSAPP, YOUTUBE
  apiKey          String?
  apiSecret       String?
  appId           String?
  pageId          String?
  instagramId     String?
  accessToken     String?
  refreshToken    String?
  webhookUrl      String?
  isActive        Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

model SocialPost {
  id          String   @id @default(cuid())
  postId      String?  
  summary     String
  videoUrl    String
  status      String   @default("DRAFT") // DRAFT, SCHEDULED, POSTED, FAILED
  scheduledTo DateTime?
  postedAt    DateTime?
  platform    String   @default("META")
  postType    String   @default("REEL") // REEL | STORY
  log         String?
  thumbUrl    String?  // URL de thumbnail (MinIO)
  metaContainerId String? // ID do container criado na Meta (para publicação async)
  postUrl     String?  // URL pública da postagem
  views       Int      @default(0) // Visualizações
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post        Post?    @relation(fields: [postId], references: [id])
  codeVideoProjectId String?
  codeVideoProject   CodeVideoProject? @relation(fields: [codeVideoProjectId], references: [id])
}

model CodeVideoProject {
  id               String           @id @default(cuid())
  status           String           @default("DRAFT") // DRAFT | GENERATING | READY | RENDERING | DONE | FAILED

  // Entrada do usuário
  ideaPrompt       String
  aspectRatio      VideoAspectRatio @default(PORTRAIT_9_16)
  videoDurationSec Int              @default(30)
  fps              Int              @default(30)
  // TTS (worker Python / edge-tts)
  ttsVoice         String           @default("pt-BR-AntonioNeural")
  ttsSpeed         String           @default("+5%")
  useExternalMedia Boolean          @default(false)

  // Conteúdo editável (IA -> usuário pode revisar)
  title            String?
  description      String?
  narrationText    String?

  // Plano do vídeo (JSON serializado, validado no backend)
  videoSpecJson    String           @default("{}")

  // Artefatos gerados
  audioUrl         String?
  captionsUrl      String?
  videoUrl         String?
  thumbUrl         String?
  renderProgress   Float            @default(0)

  errorMessage     String?
  log              String?

  socialPosts      SocialPost[]
  question         VideoQuestion?

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model VideoQuestionConfig {
  id                String   @id @default(cuid())
  isEnabled         Boolean  @default(true)

  // Agendamento
  intervalMinutes   Int      @default(60)      // executa a cada X minutos
  scheduledTimes    String   @default("[]")    // JSON: ["08:00","14:00"]
  useScheduledTimes Boolean  @default(false)

  // Limites
  maxQuestionsPerRun Int     @default(3)

  // Defaults do vídeo
  defaultAspectRatio VideoAspectRatio @default(PORTRAIT_9_16)
  videoDurationSec   Int      @default(30)
  fps                Int      @default(30)
  ttsVoice           String   @default("pt-BR-AntonioNeural")
  ttsSpeed           String   @default("+5%")

  // Pós-processo
  autoEnqueueMetaStory  Boolean @default(false)
  autoEnqueueMetaReels  Boolean @default(false)
  autoEnqueueTikTok   Boolean @default(false)
  autoEnqueueLinkedIn Boolean @default(false)
  autoEnqueueYouTube  Boolean @default(false)
  useExternalMedia    Boolean @default(false)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model VideoQuestion {
  id               String   @id @default(cuid())
  questionText     String
  status           String   @default("PENDING") // PENDING | PROCESSING | DONE | FAILED
  errorMessage     String?
  startedAt        DateTime?
  completedAt      DateTime?
  useExternalMedia Boolean   @default(false)

  codeVideoProjectId String? @unique
  codeVideoProject   CodeVideoProject? @relation(fields: [codeVideoProjectId], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Lead {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String?  // Ref do Post (Slug) para saber onde o lead foi captado
  createdAt DateTime @default(now())
}

model CrmSettings {
  id                     String   @id @default(cuid())
  whatsappEnabled        Boolean  @default(false)
  whatsappDisplayLabel   String   @default("Falar no WhatsApp")
  whatsappNumber         String?
  whatsappDefaultMessage String   @default("Olá! Quero falar sobre automação, agentes de IA e WhatsApp.")
  evolutionEnabled       Boolean  @default(false)
  evolutionBaseUrl       String?
  evolutionApiKey        String?
  evolutionInstanceName  String?
  evolutionWebhookSecret String?
  openAiModel            String   @default("gpt-4o-mini")
  assistantEnabled       Boolean  @default(true)
  assistantScope         String   @default("Automação com n8n, agentes de IA, RAG, WhatsApp, Evolution API, integrações e implantação comercial.")
  assistantSystemPrompt  String   @default("Você é um atendente comercial da Plugando IA. Tire dúvidas apenas sobre automação, n8n, agentes de IA, RAG, WhatsApp, Evolution API, integrações, implantação e consultoria. Se o assunto sair desse escopo, recuse com educação, explique o escopo atendido e convide o lead a voltar ao tema comercial.")
  defaultAssigneeUserId  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  defaultAssignee        User?    @relation("CrmDefaultAssignee", fields: [defaultAssigneeUserId], references: [id])
}

model CrmContact {
  id              String       @id @default(cuid())
  name            String?
  phone           String       @unique
  email           String?      @unique
  company         String?
  source          String?
  interestService String?
  notes           String?
  stage           CrmLeadStage @default(LEAD)
  lastContactAt   DateTime?
  ownerUserId     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  owner           User?              @relation("CrmContactOwner", fields: [ownerUserId], references: [id])
  activities      CrmActivity[]
  tasks           CrmTask[]
  conversations   CrmConversation[]

  @@index([stage])
  @@index([ownerUserId])
  @@index([createdAt])
}

model CrmActivity {
  id           String               @id @default(cuid())
  contactId    String
  type         CrmActivityType
  direction    CrmActivityDirection @default(INTERNAL)
  subject      String?
  content      String
  happenedAt   DateTime             @default(now())
  createdAt    DateTime             @default(now())
  authorUserId String?
  metadataJson String               @default("{}")

  contact      CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author       User?      @relation("CrmActivityAuthor", fields: [authorUserId], references: [id])

  @@index([contactId, happenedAt])
  @@index([type])
}

model CrmTask {
  id               String        @id @default(cuid())
  contactId        String
  title            String
  description      String?
  status           CrmTaskStatus @default(OPEN)
  dueAt            DateTime?
  completedAt      DateTime?
  assignedToUserId String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  contact          CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedTo       User?      @relation("CrmTaskAssignee", fields: [assignedToUserId], references: [id])

  @@index([contactId, status])
  @@index([assignedToUserId])
}

model CrmConversation {
  id               String   @id @default(cuid())
  contactId        String
  channel          String   @default("WHATSAPP")
  status           String   @default("OPEN")
  externalThreadId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  contact          CrmContact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages         CrmMessage[]

  @@index([contactId, updatedAt])
}

model CrmMessage {
  id                 String               @id @default(cuid())
  conversationId     String
  role               String
  direction          CrmActivityDirection @default(INTERNAL)
  content            String
  model              String?
  externalMessageId  String?
  guardrailTriggered Boolean              @default(false)
  createdAt          DateTime             @default(now())

  conversation       CrmConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model PipelineLog {
  id        String   @id @default(cuid())
  step      String   // FETCH, AI, VIDEO, UPLOAD, INGEST, PEXELS, ERROR
  message   String
  level     String   @default("INFO") // INFO, SUCCESS, ERROR, WARN
  createdAt DateTime @default(now())
}

model ScraperConfig {
  id                String   @id @default(cuid())
  // Agendamento
  intervalHours     Int      @default(6)
  scheduledTimes    String   @default("[]")    // JSON: ["08:00","14:00"]
  useScheduledTimes Boolean  @default(false)   // true = horários fixos; false = intervalo
  isEnabled         Boolean  @default(true)
  // Limites
  maxArticlesPerRun Int      @default(3)       // 3 | 5 | 7 | 10
  // Modelo de IA
  aiModel           String   @default("gpt-4o-mini")
  aiTemperature     Float    @default(0.7)
  // Prompt
  systemPrompt      String   @default("")
  // Vídeo
  videoDurationSec  Int      @default(30)      // 30 | 60 | 90 | 120 | 180 | 300
  videoStyle        String   @default("journalism") // journalism|story|ad|funny|ironic
  // TTS
  ttsVoice          String   @default("pt-BR-AntonioNeural")
  ttsSpeed          String   @default("+5%")
  // Pexels
  pexelsEnabled     Boolean  @default(true)
  // Auto-publicação por plataforma
  autoPublishReels    Boolean  @default(false)
  autoPublishStory    Boolean  @default(false)
  autoPublishTikTok   Boolean  @default(false)
  autoPublishLinkedIn Boolean  @default(false)
  autoPublishYouTube  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ScraperRun {
  id             String       @id @default(cuid())
  startedAt      DateTime
  finishedAt     DateTime?
  status         String       @default("RUNNING") // RUNNING | SUCCESS | FAILED | PARTIAL
  articlesFound  Int          @default(0)
  articlesSaved  Int          @default(0)
  triggerType    String       @default("AUTO")    // AUTO | MANUAL
  errorMessage   String?
  totalTokensIn  Int          @default(0)
  totalTokensOut Int          @default(0)
  totalCostUsd   Float        @default(0)
  createdAt      DateTime     @default(now())

  aiUsageLogs    AiUsageLog[]
}

model AiUsageLog {
  id               String      @id @default(cuid())
  runId            String?
  postId           String?
  operation        String      // rewrite_article
  model            String
  promptTokens     Int         @default(0)
  completionTokens Int         @default(0)
  totalTokens      Int         @default(0)
  costUsd          Float       @default(0)
  inputSummary     String?
  outputSummary    String?
  createdAt        DateTime    @default(now())

  run              ScraperRun? @relation(fields: [runId], references: [id])
  post             Post?       @relation(fields: [postId], references: [id])
}

// ═══════════════════════════════════════════════════════════════
// YouTube Analytics Module
// ═══════════════════════════════════════════════════════════════

model YtCategory {
  id        String   @id @default(cuid())
  name      String   @unique  // "Entretenimento / Humor"
  slug      String   @unique  // "entretenimento-humor"
  color     String   @default("#6366f1")
  icon      String?  // Nome do ícone MUI
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channels  YtChannel[]
}

model YtChannel {
  id                String   @id @default(cuid())
  youtubeChannelId  String   @unique
  name              String
  handle            String?
  description       String?
  thumbnailUrl      String?
  bannerUrl         String?
  country           String?
  customUrl         String?

  // Métricas atuais (última coleta)
  subscribers       BigInt   @default(0)
  totalViews        BigInt   @default(0)
  totalVideos       Int      @default(0)

  // Métricas calculadas
  viewsShorts       BigInt   @default(0)
  viewsLongs        BigInt   @default(0)
  viewsLives        BigInt   @default(0)
  avgViewsPerVideo  Float    @default(0)
  avgViewsPerShort  Float    @default(0)
  weeklyGrowth      Float    @default(0)
  monthlyGrowth     Float    @default(0)
  uploadsThisWeek   Int      @default(0)
  uploadsThisMonth  Int      @default(0)
  subsGainedWeek    Int      @default(0)
  subsGainedMonth   Int      @default(0)
  livesPerMonth     Float    @default(0)
  lastVideoAt       DateTime?

  // Ranking
  rankPosition      Int      @default(0)

  // Relações
  categoryId        String
  category          YtCategory @relation(fields: [categoryId], references: [id])

  isActive          Boolean  @default(true)
  lastFetchedAt     DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  videos            YtVideo[]
  snapshots         YtChannelSnapshot[]
  aiReports         YtAiReport[]

  @@index([categoryId])
  @@index([rankPosition])
}

model YtVideo {
  id              String   @id @default(cuid())
  youtubeVideoId  String   @unique
  title           String
  description     String?
  thumbnailUrl    String?

  // Tipo: SHORT | LONG | LIVE
  videoType       String   @default("LONG")

  // Métricas
  views           BigInt   @default(0)
  likes           Int      @default(0)
  comments        Int      @default(0)
  duration        Int      @default(0) // segundos

  // Temporal
  publishedAt     DateTime
  dayOfWeek       Int?     // 0=Dom, 6=Sab
  hourOfDay       Int?     // 0-23

  // Relações
  channelId       String
  channel         YtChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  snapshots       YtVideoSnapshot[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([channelId])
  @@index([channelId, publishedAt])
  @@index([videoType])
}

model YtChannelSnapshot {
  id               String   @id @default(cuid())

  subscribers      BigInt
  totalViews       BigInt
  totalVideos      Int
  viewsShorts      BigInt   @default(0)
  viewsLongs       BigInt   @default(0)

  // Deltas desde snapshot anterior
  deltaSubscribers Int      @default(0)
  deltaViews       BigInt   @default(0)
  deltaVideos      Int      @default(0)

  channelId        String
  channel          YtChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  snapshotDate     DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([channelId, snapshotDate])
  @@index([snapshotDate])
}

model YtVideoSnapshot {
  id           String   @id @default(cuid())

  views        BigInt
  likes        Int      @default(0)
  comments     Int      @default(0)

  videoId      String
  video        YtVideo  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  snapshotDate DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([videoId, snapshotDate])
}

model YtAiReport {
  id               String   @id @default(cuid())

  // Conteúdo
  summary          String   // Resumo executivo
  insights         String   // JSON com insights detalhados
  recommendations  String   // JSON com recomendações
  rawResponse      String?  // Resposta bruta da IA

  // Metadados
  model            String   @default("gpt-4o-mini")
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  costUsd          Float    @default(0)

  // Relação
  channelId        String
  channel          YtChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())

  @@index([channelId, createdAt])
}
