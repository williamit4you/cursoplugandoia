NEXT_PUBLIC_CHECKOUT_URL="https://pay.hotmart.com/M103626951G?off=by19achj&bid=1775680433634"

# URL pública do site (usada em alguns links/páginas estáticas).
# Em produção, aponte para o domínio final (ex.: https://plugandoia.cloud).
# NEXT_PUBLIC_SITE_URL="https://plugandoia.cloud"

# OpenAI (needed for Videos com codigo generation)
# OPENAI_API_KEY=sk-...
# VIDEO_CODE_AI_MODEL=gpt-4o-mini

# Python worker base URL (edge-tts/whisper). Used to generate narration audio.
# WORKER_FASTAPI_BASE_URL=http://localhost:8000

# Modal media workers
# MODAL_AUDIO_ENDPOINT=https://<your-modal-app>-generate-audio.modal.run
# MODAL_VIDEO_ENDPOINT=https://<your-modal-app>-generate-video.modal.run

# Cron interno do Next standalone.
# Em producao, liga por padrao. Defina false para usar apenas cron externo.
INTERNAL_CRON_ENABLED=true
INTERNAL_CRON_TICK_MS=60000

# TikTok publishing mode:
# - browser: usa o tiktok-uploader como modo principal
# - official: usa apenas a API oficial antiga
# - auto: tenta primeiro o uploader e so depois a API oficial, se houver token
TIKTOK_UPLOAD_METHOD=browser

# Comando disponivel no servidor para o fallback inspirado no projeto
# https://github.com/wkaisertexas/tiktok-uploader
# Exemplo de instalacao:
#   pip install tiktok-uploader
#   playwright install
TIKTOK_UPLOADER_COMMAND=tiktok-uploader
TIKTOK_UPLOADER_HEADLESS=true
TIKTOK_UPLOADER_BROWSER=chrome
